@using System.Linq.Expressions
@inject IJSRuntime JSRuntime

<div style="position: relative; display: block;">
    <textarea @ref="textareaRef" name="@FieldIdentifier.FieldName" rows="@Rows"
              class="form-control" placeholder="@Placeholder"
              readonly="@ReadOnly"
              style="@(HasCopyButton ? "padding-right: 24px;" : null)"
              @onchange="UpdateValue" @attributes="AdditionalAttributes">@internalValue</textarea>
    @if (HasCopyButton)
    {
        <button type="button"
                style="position: absolute; top: 6px; right: 6px; background: none; border: none; padding: 2px; cursor: pointer; opacity: 0.5; line-height: 1;"
                @onclick="CopyToClipboardAsync"
                title="Скопировать">
            <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="12" height="12" class="g-icon" fill="currentColor" stroke="none" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 16 16"><path fill="currentColor" fill-rule="evenodd" d="M12 2.5H8A1.5 1.5 0 0 0 6.5 4v1H8a3 3 0 0 1 3 3v1.5h1A1.5 1.5 0 0 0 13.5 8V4A1.5 1.5 0 0 0 12 2.5M11 11h1a3 3 0 0 0 3-3V4a3 3 0 0 0-3-3H8a3 3 0 0 0-3 3v1H4a3 3 0 0 0-3 3v4a3 3 0 0 0 3 3h4a3 3 0 0 0 3-3zM4 6.5h4A1.5 1.5 0 0 1 9.5 8v4A1.5 1.5 0 0 1 8 13.5H4A1.5 1.5 0 0 1 2.5 12V8A1.5 1.5 0 0 1 4 6.5" clip-rule="evenodd"></path></svg></svg>
        </button>
    }
</div>

@code {
    [CascadingParameter]
    private EditContext? EditContext { get; set; }

    [Parameter]
    [EditorRequired]
    public string Value { get; set; } = "";

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public Expression<Func<string>>? ValueExpression { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public int Rows { get; set; } = 4;

    /// <summary>When true, the textarea is rendered with the <c>readonly</c> attribute.</summary>
    [Parameter]
    public bool ReadOnly { get; set; }

    /// <summary>When true, a small copy icon is rendered in the top-right corner of the textarea.</summary>
    [Parameter]
    public bool HasCopyButton { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private FieldIdentifier FieldIdentifier { get; set; }
    private string internalValue = "";
    private ElementReference textareaRef;

    protected override void OnInitialized()
    {
        internalValue = Value;
        if (ValueExpression is not null)
        {
            FieldIdentifier = FieldIdentifier.Create(ValueExpression);
        }
    }

    private async Task UpdateValue(ChangeEventArgs eventArgs)
    {
        internalValue = (string?)eventArgs.Value ?? "";
        await ValueChanged.InvokeAsync(internalValue);
        if (ValueExpression is not null)
        {
            EditContext?.NotifyFieldChanged(FieldIdentifier);
        }
    }

    private async Task CopyToClipboardAsync()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", internalValue);
    }
}
