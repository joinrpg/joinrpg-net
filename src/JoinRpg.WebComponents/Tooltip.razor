@if(string.IsNullOrWhiteSpace(Title) && TooltipContent is null)
{
    @ChildContent
    return;
}

<span class="join-tooltip-container">
    <span>
        @ChildContent
    </span>
    <span class="join-tooltip">
        @if (TooltipContent is not null)
        {
            @TooltipContent
        }
        else
        {
            @Title
        }
    </span>
</span>

@code {
    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public RenderFragment? TooltipContent { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}

