<span class="dropdown">
    <button class="@ButtonClass dropdown-toggle"
            type="button"
            id="@_menuId"
            data-toggle="dropdown"
            aria-haspopup="true"
            aria-expanded="true">
        <span title="действия" class="glyphicon glyphicon-option-vertical"></span>
    </button>
    <ul class="dropdown-menu" aria-labelledby="@_menuId">
        @ChildContent
    </ul>
</span>

@code {
    [Parameter, EditorRequired] public RenderFragment ChildContent { get; set; } = null!;

    /// <summary>
    /// Размер кнопки — та же шкала, что у <see cref="JoinButton"/>, чтобы меню
    /// совпадало по высоте с кнопками рядом.
    /// </summary>
    [Parameter] public SizeStyleEnum Size { get; set; } = SizeStyleEnum.Small;

    private string ButtonClass => BootstrapStyle.Build("btn", VariationStyleEnum.None, Size);

    private readonly string _menuId = $"dots-menu-{Guid.NewGuid():N}";
}
