@using System.Linq.Expressions
@inject IProjectListClient client

<TypedSelector TKey="ProjectIdentification" TItem="ProjectLinkViewModel"
    Name="@Name"
    Items="items"
    KeySelector="@(i => i.ProjectId)"
    ToListItem="@(i => TypedSelectList.CreateItem(
        Value: i.ProjectId,
        Text: i.ProjectName))"
    SelectedValues="@Selected"
    SelectedItemsChanged="@HandleSelectedChanged"
    Multiple="false"
    />

@code {

    [CascadingParameter] public EditContext? EditContext { get; set; }
    [Parameter] public string? Name { get; set; } = null;
    [Parameter] public ProjectIdentification? ProjectId { get; set; }
    [Parameter] public EventCallback<ProjectIdentification?> ProjectIdChanged { get; set; }
    [Parameter] public Expression<Func<ProjectIdentification?>>? ProjectIdExpression { get; set; }

    [Parameter] public ProjectLinkViewModel? Project { get; set; }
    [Parameter] public EventCallback<ProjectLinkViewModel?> ProjectChanged { get; set; }
    [EditorRequired]
    [Parameter] public ProjectSelectionCriteria Criteria { get; set; }

    private ProjectIdentification[] Selected { get; set; } = [];
    private ProjectLinkViewModel[]? items;
    private FieldIdentifier? fieldIdentifier = null;

    protected override async Task OnInitializedAsync()
    {
        items = [.. await client.GetProjects(Criteria)];
        if (ProjectIdExpression is not null)
        {
            fieldIdentifier = FieldIdentifier.Create(ProjectIdExpression);
            Name ??= fieldIdentifier.Value.FieldName;
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        if (ProjectId is not null)
        {
            Selected = [ ProjectId ];
        }
        else if (Project is not null)
        {
            Selected = [ Project.ProjectId ];
        }
    }

    private async Task HandleSelectedChanged(ProjectLinkViewModel[] values)
    {
        var selected = values.Length == 0 ? null : values.Single();
        await ProjectIdChanged.InvokeAsync(selected?.ProjectId);
        await ProjectChanged.InvokeAsync(selected);
        if (EditContext is not null && fieldIdentifier is not null)
        {
            EditContext.NotifyFieldChanged(fieldIdentifier.Value);
        }
    }
}
