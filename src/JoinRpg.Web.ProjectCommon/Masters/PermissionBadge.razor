<JoinBadge Variation="@(Model.Value ? VariationStyleEnum.Success : VariationStyleEnum.None)" Title="@Model.Description">
    @if (Model.Value)
    {
        <span class="glyphicon glyphicon-ok-sign"></span>
    }
    else
    {
        <span class="glyphicon glyphicon-remove-sign"></span>
    }
    @Model.DisplayName
</JoinBadge>
<br />

@code {
    [Parameter, EditorRequired] public PermissionBadgeViewModel Model { get; set; } = null!;
}
