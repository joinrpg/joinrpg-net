@inject ICharacterUriLocator characterUriLocator
@inject IUriLocator<ClaimIdentification> claimUriLocator
<span class="character-link-with-edit">
    <CharacterLink Model="Model.Character" />
    @if (Model.CanEdit)
    {
        <JoinIconButton Preset="ButtonPreset.Edit" Link="@characterUriLocator.GetEditUri(Model.Character.CharacterId).ToString()" Title="Редактировать персонажа" />
    }
    @if (Model.ApprovedClaimId is { } claimId)
    {
        <JoinIconButton Preset="ButtonPreset.Claim" Link="@claimUriLocator.GetUri(claimId).ToString()" Title="Принятая заявка" />
    }
</span>

@code {
    [Parameter]
    [EditorRequired]
    public CharacterLinkWithEditViewModel Model { get; set; } = null!;
}
