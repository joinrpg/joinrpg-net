@model JoinRpg.Web.Plots.PlotElementCreateViewModel

@{
    ViewBag.Title = "Добавить вводную";
}

<h2>@ViewBag.Title</h2>

@using (Html.BeginForm("")) 
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <component type="typeof(JoinRpg.Web.Plots.PlotElementEditPanel)"
                   param-Model="@Model"
                   render-mode="WebAssemblyPrerendered" />

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Добавить вводную" class="btn btn-success" />
            </div>
        </div>
    </div>
}
