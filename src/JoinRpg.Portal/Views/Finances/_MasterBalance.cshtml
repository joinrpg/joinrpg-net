
@model IEnumerable<JoinRpg.Web.Models.MasterBalanceViewModel>

<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Master)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Total)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FeeBalance)
        </th>

        <th>
            @Html.DisplayNameFor(model => model.ReceiveBalance)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.SendBalance)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.ExpensesBalance)
        </th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Master)
            @if (ViewBag.ShowLinks == true)
            {
                @Html.ActionLink("(подробнее)", "ByMaster", new {item.ProjectId, MasterId = item.Master.UserId})
            }
        </td>
        <td>
            @(await Html.RenderComponentAsync<PriceElement>(RenderMode.Static, new { Price = item.Total }))
        </td>
        <td>
            @(await Html.RenderComponentAsync<PriceElement>(RenderMode.Static, new { Price = item.FeeBalance }))
        </td>
        <td>
            @(await Html.RenderComponentAsync<PriceElement>(RenderMode.Static, new { Price = item.ReceiveBalance }))
        </td>
        <td>
            @(await Html.RenderComponentAsync<PriceElement>(RenderMode.Static, new { Price = item.SendBalance }))
        </td>
        <td>
            @(await Html.RenderComponentAsync<PriceElement>(RenderMode.Static, new { Price = item.ExpensesBalance }))
        </td>
    </tr>
}

</table>
