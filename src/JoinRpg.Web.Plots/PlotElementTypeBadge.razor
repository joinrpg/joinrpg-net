@switch (ElementType)
{
    case PlotElementTypeView.RegularPlot:
        break;
    case PlotElementTypeView.Handout:
        <JoinBadge Variation="VariationStyleEnum.Info"> Раздатка </JoinBadge>
        break;
    default:
        throw new ArgumentOutOfRangeException();
}
@if (IsMasterOnly)
{
    <JoinBadge Variation="VariationStyleEnum.Warning"> Мастерский </JoinBadge>
}
@code
{
    [Parameter]
    [EditorRequired]
    public PlotElementTypeView ElementType { get; set; }

    [Parameter]
    public bool IsMasterOnly { get; set; }
}
