<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>JoinRpg.Common.PrimitiveTypes</PackageId>
    <Description>Common primitive types for JoinRpg (emails, user IDs, etc.)</Description>
    <PackageProjectUrl>https://github.com/joinrpg/joinrpg-net</PackageProjectUrl>
    <RepositoryUrl>https://github.com/joinrpg/joinrpg-net</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <!-- Using NuGet package instead of ProjectReference to avoid recompilation issues with language server -->
    <PackageReference Include="JoinRpg.Common.PrimitiveTypes.SourceGenerator" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="JoinRpg.Domain.Test" />
    <InternalsVisibleTo Include="JoinRpg.WebPortal.Models.Test" />
    <InternalsVisibleTo Include="JoinRpg.DataModel.Mocks" />
  </ItemGroup>

</Project>
