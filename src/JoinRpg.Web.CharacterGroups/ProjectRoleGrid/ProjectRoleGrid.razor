@using JoinRpg.DomainTypes.ProjectMetadata
@using JoinRpg.Web.CharacterGroups.GroupEditMenu
@using JoinRpg.Web.ProjectCommon
@using JoinRpg.Web.ProjectCommon.Characters
@using JoinRpg.WebComponents
@inject IProjectRoleGridClient Client
@inject NavigationManager NavigationManager
@inject PersistentComponentState ApplicationState
@implements IDisposable

@if (Result is null)
{
    <JoinLoadingMessage />
}
else if (!Result.HasAccess)
{
    <JoinNoAccessToProjectPanel Model="Result.NoAccess!" />
}
else
{
    var Model = Result.Grid!;
    @* Портал на Bootstrap 3 — flex-утилит (d-flex и т.п.) нет, поэтому inline-стили. *@
    <div style="display: flex; align-items: center; gap: 12px;">
        <h1 style="margin: 0;">@Model.Name</h1>
        @* Medium = обычный размер, как у JoinButton «Настройки сетки» рядом. *@
        <GroupEditMenu GroupId="Model.RootGroupId"
                       GroupType="Model.RootGroupType"
                       ShowEditControls="Model.CanEditSettings"
                       Size="SizeStyleEnum.Medium" />
        @if (Model.CanEditSettings)
        {
            <JoinButton Preset="ButtonPreset.Edit"
                        OnClick='() => NavigationManager.NavigateTo($"/{Model.RolesListId.ProjectId.Value}/tools/roleslist/edit/{Model.RolesListId.ProjectRolesListId}")'
                        Label="Настройки сетки" />
        }
    </div>
    @if (Model.GroupsViewMode == RolesGridGroupsViewMode.Tree)
    {
        var currentDepth = 0;
        @foreach (var block in _renderBlocks)
        {
            @if (block is ProjectRoleGridGroupHeaderRowViewModel groupHeader)
            {
                currentDepth = groupHeader.Depth;
                <div style="margin-left: @(groupHeader.Depth)em">
                    @if (groupHeader.Depth > 0)
                    {
                        <span class="@HeaderClass(groupHeader.Depth)" title="@groupHeader.Path">
                            <CharacterGroupLink Model="groupHeader.Group" />
                        </span>
                        <GroupEditMenu GroupId="groupHeader.Group.CharacterGroupId"
                                       GroupType="groupHeader.GroupType"
                                       ShowEditControls="Model.CanEditSettings" />
                        @if (groupHeader.IsSpecial)
                        {
                            string title = "Эта группа автоматически заполняется в зависимости от полей персонажа." + groupHeader.BoundExpression;
                            <JoinBadge Title="title">Спецгруппа</JoinBadge>
                        }
                        @if (!groupHeader.FirstCopy)
                        {
                            <span>см. выше</span>
                        }
                    }
                    @if (groupHeader.Description is { } description)
                    {
                        <div>@description</div>
                    }
                </div>
            }
            else if (block is List<ProjectRoleGridCharacterRowViewModel> charBlock)
            {
                <div style="margin-left: @(currentDepth)em">
                    <ul>
                        @foreach (var charRow in charBlock)
                        {
                            <li>
                                <CharacterLinkWithEdit Model="charRow.Character" />
                                @if (charRow.Character.CanEdit && charBlock.Count > 1)
                                {
                                    <JoinMoveControl TItem="ProjectRoleGridCharacterRowViewModel"
                                                     Items="charBlock"
                                                     Self="charRow"
                                                     SkipGroup="true"
                                                     Size="SizeStyleEnum.ExtraSmall"
                                                     OnMoveCompleted="StateHasChanged" />
                                }
                                <text> </text>
                                <ProjectRoleGridPlayerCell Row="charRow" />
                                @if (charRow.Groups is { } groups && groups.Groups.Count > 0)
                                {
                                    <div>
                                        Группы:
                                        @for (var i = 0; i < groups.Groups.Count; i++)
                                        {
                                            if (i > 0)
                                            {
                                                <text>, </text>
                                            }
                                            <CharacterGroupLink Model="groups.Groups[i]" />
                                        }
                                    </div>
                                }
                                @if (!charRow.FirstCopy)
                                {
                                    @if (Model.FieldColumnNames.Count > 0)
                                    {
                                        <div>(см. выше)</div>
                                    }
                                }
                                else
                                {
                                    @for (var i = 0; i < charRow.FieldValues.Count; i++)
                                    {
                                        @if (!string.IsNullOrWhiteSpace(charRow.FieldValues[i]))
                                        {
                                            @if (Model.SuppressFieldLabels)
                                            {
                                                <div>@charRow.FieldValues[i]</div>
                                            }
                                            else
                                            {
                                                <div><strong>@Model.FieldColumnNames[i]</strong>: @charRow.FieldValues[i]</div>
                                            }
                                        }
                                    }
                                }
                            </li>
                        }
                    </ul>
                </div>
            }
        }
    }
    else
    {
    <table class="table">
        <thead>
            <tr>
                <th>Персонаж</th>
                <th>Игрок</th>
                @if (Model.HasGroupsColumn)
                {
                    <th>Группы</th>
                }
                @foreach (var fieldName in Model.FieldColumnNames)
                {
                    <th>@fieldName</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var block in _renderBlocks)
            {
                @if (block is ProjectRoleGridGroupHeaderRowViewModel groupHeader)
                {
                    var colspan = 2 + (Model.HasGroupsColumn ? 1 : 0) + Model.FieldColumnNames.Count;
                    <tr class="table-secondary">
                        <td colspan="@colspan">
                            <strong><CharacterGroupLink Model="groupHeader.Group" /></strong>
                            <GroupEditMenu GroupId="groupHeader.Group.CharacterGroupId"
                                          GroupType="groupHeader.GroupType"
                                          ShowEditControls="Model.CanEditSettings" />
                            @if (groupHeader.Description is { } description)
                            {
                                <br />@description
                            }
                        </td>
                    </tr>
                }
                else if (block is List<ProjectRoleGridCharacterRowViewModel> charBlock)
                {
                    @foreach (var charRow in charBlock)
                    {
                        <tr>
                            <td>
                                <CharacterLinkWithEdit Model="charRow.Character" />
                                @if (charRow.Character.CanEdit && charBlock.Count > 1)
                                {
                                    <JoinMoveControl TItem="ProjectRoleGridCharacterRowViewModel"
                                                      Items="charBlock"
                                                      Self="charRow"
                                                      SkipGroup="true"
                                                      Size="SizeStyleEnum.ExtraSmall"
                                                      OnMoveCompleted="StateHasChanged" />
                                }
                            </td>
                            <td>
                                <ProjectRoleGridPlayerCell Row="charRow" />
                            </td>
                            @if (charRow.Groups is { } groups)
                            {
                                <td>
                                    @for (var i = 0; i < groups.Groups.Count; i++)
                                    {
                                        if (i > 0)
                                        {
                                            <text>, </text>
                                        }
                                        <CharacterGroupLink Model="groups.Groups[i]" />
                                    }
                                </td>
                            }
                            @foreach (var fieldValue in charRow.FieldValues)
                            {
                                <td>@fieldValue</td>
                            }
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
    }
}

@code {
    [Parameter, EditorRequired] public ProjectRolesListIdentification RolesListId { get; set; }

    private ProjectRoleGridViewResult? Result { get; set; }
    private PersistingComponentStateSubscription _persistingSubscription;
    private List<object> _renderBlocks = [];

    // Заголовки уровней как в классической сетке ролей: 1 → h2, 2 → h3, глубже → h4.
    private static string HeaderClass(int depth) => depth switch
    {
        1 => "h2",
        2 => "h3",
        _ => "h4",
    };

    protected override async Task OnInitializedAsync()
    {
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistData);

        if (!ApplicationState.TryTakeFromJson<ProjectRoleGridViewResult>(nameof(ProjectRoleGrid), out var result))
        {
            result = await Client.GetRoleGrid(RolesListId);
        }
        Result = result;

        if (result?.Grid is { } grid)
        {
            BuildRenderBlocks(grid);
        }
    }

    // Character-строки одной группы в Model.Rows всегда идут подряд (см. BuildRows в
    // ProjectRoleGridViewModelBuilder), поэтому их можно безопасно схлопывать в изменяемый
    // список: он же передаётся в JoinMoveControl.Items, и перестановка внутри него сразу
    // видна в рендере — без похода на сервер за всей сеткой заново.
    private void BuildRenderBlocks(ProjectRoleGridViewModel grid)
    {
        _renderBlocks = [];
        List<ProjectRoleGridCharacterRowViewModel>? current = null;
        foreach (var row in grid.Rows)
        {
            if (row is ProjectRoleGridCharacterRowViewModel charRow)
            {
                if (current is null)
                {
                    current = [];
                    _renderBlocks.Add(current);
                }
                current.Add(charRow);
            }
            else
            {
                current = null;
                _renderBlocks.Add(row);
            }
        }
    }

    private Task PersistData()
    {
        // Почему-то Description отваливается. ApplicationState.PersistAsJson(nameof(ProjectRoleGrid), Result);
        return Task.CompletedTask;
    }

    public void Dispose() => _persistingSubscription.Dispose();
}
